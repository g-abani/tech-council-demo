# =============================================================================
# Environment Configuration
# Copy this file to .env and fill in the values
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Azure OpenAI
# -----------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_API_INSTANCE_NAME=your-instance-name
AZURE_OPENAI_API_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_EMBEDDINGS_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# -----------------------------------------------------------------------------
# Azure AI Search (used by the RAG / knowledge-base tool)
# -----------------------------------------------------------------------------
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_API_KEY=your-azure-search-api-key
AZURE_SEARCH_INDEX=your-index-name

# -----------------------------------------------------------------------------
# LangSmith Tracing (optional – remove or set LANGSMITH_TRACING=false to disable)
# -----------------------------------------------------------------------------
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=your-langsmith-project
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# -----------------------------------------------------------------------------
# JIRA Access – IMS credentials (service-to-service auth)
# -----------------------------------------------------------------------------
JIRA_IMS_CLIENT_ID=your-ims-client-id
JIRA_IMS_CLIENT_SECRET=your-ims-client-secret
JIRA_IMS_CLIENT_CODE=your-ims-client-code

# JIRA user credentials
JIRA_USERNAME=your-jira-username
JIRA_PASSWORD=your-jira-password
JIRA_URL=https://jira.corp.adobe.com

# iPaaS JIRA proxy
IPAAS_JIRA_ENDPOINT=https://ipaasapi.adobe-services.com/jira/rest/api/2/search
IPAAS_JIRA_API_KEY=your-ipaas-api-key
IPAAS_JIRA_BASE_URL=https://ipaasapi.adobe-services.com

# -----------------------------------------------------------------------------
# PostgreSQL — optional `lookup_member` demo + UI member dropdown for Graph RBAC (GET /api/members)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/tech_council_demo
# (or use POSTGRES_URL — same value)

# -----------------------------------------------------------------------------
# Microsoft Graph — Entra RBAC (server-side group membership via checkMemberGroups)
# Application permissions + client credentials. Do not expose client secret to browsers.
# Typical permissions: GroupMember.Read.All, User.Read.All (user-by-email lookup + checkMemberGroups; org-dependent).
# Token: POST https://login.microsoftonline.com/{TENANT_ID}/oauth2/v2.0/token
# API: https://graph.microsoft.com/v1.0
# -----------------------------------------------------------------------------
# MS_GRAPH_TENANT_ID=
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=
# Map Entra security groups to roles (optional per tier — checked admin → editor → viewer).
# Each value must be the group's Object Id (GUID), e.g. a1b2c3d4-e5f6-7890-abcd-ef1234567890 — not display name or mail nickname.
# MS_GRAPH_GROUP_OBJECT_ID_VIEWER=
# MS_GRAPH_GROUP_OBJECT_ID_EDITOR=
# MS_GRAPH_GROUP_OBJECT_ID_ADMIN=
# Optional — unified search: only include groups whose mail ends with @<domain> (omit = all groups)
# MS_GRAPH_GROUP_MAIL_DOMAIN=
# When SECURE_AGENT_RBAC_SOURCE=graph and the user is in no mapped group (or Graph fails): viewer | editor | admin
# MS_GRAPH_RBAC_NO_MATCH_ROLE=viewer
# Expose POST /api/graph/check-member for manual testing (off by default)
# SECURE_AGENT_GRAPH_DEBUG_ENDPOINT=false

# -----------------------------------------------------------------------------
# Secure Agent POC (see docs/SECURE-AGENT-POC.md)
# -----------------------------------------------------------------------------
# Step 1 — email hash vault + send_email_demo (requires input guard on): store raw emails before hashing, piiMiddleware uses strategy "hash"
# SECURE_AGENT_EMAIL_HASH_VAULT=true
# SECURE_AGENT_INPUT_GUARD=false
# SECURE_AGENT_RBAC=false
# Role source: auto (default — member picker + Graph when configured) | graph (strict Entra) | header (legacy body userRole only)
# SECURE_AGENT_RBAC_SOURCE=auto
# Comma-separated members.id and/or email local-parts (before @) that always get admin (all tools). Default includes abani,sandeep,behera,sann (seed script ids).
# SECURE_AGENT_UNIVERSAL_ADMIN_MEMBER_IDS=abani,sandeep,behera,sann
# SECURE_AGENT_OUTPUT_DLP=false
# SECURE_AGENT_HITL=false
# Ollama — JIRA sub-agent only (supervisor/workers stay on Azure OpenAI)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# JIRA_OLLAMA_MODEL=llama3.2
# OLLAMA_MODEL=llama3.2
# JIRA_OLLAMA_TEMPERATURE=0
# Dynamic supervisor routing (on unless SECURE_AGENT_DYNAMIC_MODEL=false): JIRA-like text → Ollama, else Azure by message count
# SECURE_AGENT_DYNAMIC_MODEL=false
# SECURE_AGENT_DYNAMIC_MODEL_MESSAGE_THRESHOLD=10
# SECURE_AGENT_DYNAMIC_MODEL_DEBUG=false

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3000
